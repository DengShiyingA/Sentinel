<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Sentinel uses local network to discover and connect to your Mac running Claude Code.</string>
	<key>NSCameraUsageDescription</key>
	<string>Sentinel needs camera access to scan pairing QR codes.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Sentinel uses Face ID to verify high-risk operations like terminal commands and secret file access.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_sentinel._tcp</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>sentinel</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.sentinel.ios</string>
		</dict>
	</array>
</dict>
</plist>
