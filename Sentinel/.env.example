# Sentinel 配置示例
# 复制为 .env 并填入实际值

# ========== 数据库配置 ==========
POSTGRES_PASSWORD=your_strong_postgres_password
REDIS_PASSWORD=your_strong_redis_password

# ========== 服务配置 ==========
# JWT 密钥（用于设备认证）
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# 服务器端口
PORT=3000

# ========== APNs 推送配置（可选）==========
# 如需 iOS 推送功能，填写以下信息
APNS_TEAM_ID=YOUR_TEAM_ID
APNS_KEY_ID=YOUR_KEY_ID
APNS_KEY_PATH=/app/secrets/apns-key.p8
APNS_TOPIC=com.sentinel.ios
APNS_PRODUCTION=false

# ========== CLI 配置 ==========
# sentinel-cli 连接的服务器地址
SENTINEL_SERVER_URL=http://localhost:3000
# 或者使用你的 VPS 地址
# SENTINEL_SERVER_URL=https://your-vps-domain.com

# ========== Claude Code Hook 配置 ==========
# sentinel-cli 监听的端口（Claude Code 的 hook URL）
CLI_PORT=8765
