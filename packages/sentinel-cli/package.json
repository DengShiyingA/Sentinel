{
  "name": "sentinel-guard",
  "version": "0.1.0",
  "description": "Sentinel CLI — Claude Code 本地 Hook 服务 + 移动端审批",
  "main": "dist/cli/index.js",
  "bin": {
    "sentinel": "./dist/cli/index.js"
  },
  "files": ["dist"],
  "scripts": {
